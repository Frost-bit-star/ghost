#!/data/data/com.termux/files/usr/bin/bash

# Ghost Termux Ethical Hacking Assistant - v4.8 Stable
# Developer: Frost-bit-star (https://github.com/Frost-bit-star)
MEMORY_FILE="$HOME/.ghost_memory"
AI_API="https://api.giftedtech.co.ke/api/ai/gpt4o"
API_KEY="gifted"
DEVICE_NAME=$(uname -n)
SUPPORT_LINK="https://selar.com/showlove/alchemist"
YT_LINK="https://www.youtube.com/@Mr_termux-r2l"
WA_LINK="https://whatsapp.com/channel/0029Vb7jaKx3rZZmFfefoD1a"

# Colors
R="\033[1;31m" 
C="\033[1;36m" 
Y="\033[1;33m" 
G="\033[1;32m" 
P="\033[1;35m"
W="\033[0m"    
BOLD="\033[1m"
DIM="\033[2m"

# =========================
# CORE FUNCTIONS
# =========================

type_effect() {
    local text="$1"
    for (( i=0; i<${#text}; i++ )); do
        echo -en "${text:$i:1}"
        sleep 0.01
    done
    echo
}

loading_anim() {
    local pid=$!
    local spinstr='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    echo -en "${P} 📡 GHOST ANALYZING "
    while [ -d /proc/$pid ]; do
        local temp=${spinstr#?}
        printf " %c " "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep 0.1
        printf "\b\b\b"
    done
    printf " ${G}[DONE]${W}\n"
}

draw_header() {
    clear
    echo -e "${C}${BOLD}"
    cat << "EOF"
 ░██████╗ ██╗  ██╗  ██████╗  ███████╗ ████████╗
██╔════╝ ██║  ██║ ██╔═══██╗ ██╔════╝ ╚══██╔══╝
██║  ███╗███████║ ██║   ██║ ███████╗    ██║   
██║   ██║██╔══██║ ██║   ██║ ╚════██║    ██║   
╚██████╔╝██║  ██║ ╚██████╔╝ ███████║    ██║   
 ╚═════╝ ╚═╝  ╚═╝  ╚═════╝  ╚══════╝    ╚═╝   
EOF
    echo -e "${W}${BOLD}    GHOST AGENT v4.8 - STABLE COMMAND PROTOCOL${W}"
    echo -e "${Y}    Dev: Frost-bit-star | GitHub: @Frost-bit-star${W}"
    echo -e "${DIM}    ────────────────────────────────────────────${W}"
}

show_menu() {
    echo -e "${C}╔═══════════════════════════════════════════════╗${W}"
    echo -e "${C}║${W}  ${G}1.${W} UPDATE   ${DIM}→ Sync Core Repository            ${C}║${W}"
    echo -e "${C}║${W}  ${G}2.${W} JOIN     ${DIM}→ WhatsApp Community              ${C}║${W}"
    echo -e "${C}║${W}  ${G}3.${W} DONATE   ${DIM}→ Support Alchemist               ${C}║${W}"
    echo -e "${C}║${W}  ${G}4.${W} EXIT     ${DIM}→ Terminate Session               ${C}║${W}"
    echo -e "${C}╚═══════════════════════════════════════════════╝${W}"
}

# =========================
# STARTUP
# =========================
draw_header
show_menu

if [[ ! -f "$MEMORY_FILE" ]]; then
    command -v termux-open-url &>/dev/null && termux-open-url "$YT_LINK" &>/dev/null
    touch "$MEMORY_FILE"
fi

echo -e "\n${G}Ghost is listening...${W}"

# =========================
# MAIN LOOP
# =========================
while true; do
    echo -en "${R}${BOLD}┌──(${C}${DEVICE_NAME}${R})─[${Y}~${R}]\n└─${C}$ ${W}"
    read -r USER_INPUT

    [[ -z "$USER_INPUT" ]] && continue

    case "${USER_INPUT,,}" in
        1|update)
            wget -q https://raw.githubusercontent.com/Frost-bit-star/ghost/main/ghost/usr/bin/ghost -O $PREFIX/bin/ghost && chmod +x $PREFIX/bin/ghost
            echo -e "${G}UPDATED. PLEASE RESTART.${W}" && exit 0 ;;
        2|join)
            termux-open-url "$WA_LINK" 2>/dev/null && continue ;;
        3|donate|d)
            termux-open-url "$SUPPORT_LINK" 2>/dev/null && continue ;;
        4|exit)
            exit 0 ;;
        clear)
            draw_header && show_menu && continue ;;
    esac

    SYSTEM_PROMPT="Your name is Ghost. Output ONLY the raw bash command for Termux. NO markdown. NO color codes like \033. NO explanations. Just the command."

    ( curl -sG "$AI_API" --data-urlencode "apikey=$API_KEY" --data-urlencode "q=$SYSTEM_PROMPT User: $USER_INPUT" > .tmp_resp ) &
    loading_anim
    
    # Cleaning Logic: Aggressively strips ANSI escape codes and markdown
    RESPONSE=$(jq -r '.result' .tmp_resp | sed $'s/\x1b\[[0-9;]*m//g' | sed 's/\\033//g; s/\\u001b//g; s/\[[0-9;]*m//g; s/```bash//g; s/```//g; /^\s*$/d' | head -n 1)
    rm .tmp_resp

    if [[ -z "$RESPONSE" || "$RESPONSE" == "null" ]]; then
        RESPONSE="echo 'No command found. Check connection.'"
    fi

    echo -e "${P}${BOLD}Ghost Agent Response:${W}"
    echo -e "${G}  $RESPONSE${W}"
    echo
    echo -en "${Y}Execute? (y/n): ${W}"
    read -r CONFIRM
    if [[ "$CONFIRM" == "y" ]]; then
        echo -e "${C}[*] RUNNING PROTOCOLS...${W}"
        echo -e "${DIM}------------------------------------${W}"
        # Execute and show output directly
        eval "$RESPONSE"
        echo -e "${DIM}------------------------------------${W}"
        echo -e "${G}[DONE]${W}\n"
    else
        echo -e "${R}[-] VOIDED.${W}\n"
    fi
done
