#!/data/data/com.termux/files/usr/bin/bash

# Ghost Termux Ethical Hacking Assistant - Elite Thick Frame UI

MEMORY_FILE="$HOME/.ghost_memory"
AI_API="https://api.dreaded.site/api/chatgpt"
DEVICE_NAME=$(uname -n)
SUPPORT_LINK="https://selar.com/showlove/alchemist"

# Colors
B="\033[1;34m"
G="\033[1;32m"
Y="\033[1;33m"
R="\033[1;31m"
W="\033[0m"

# =========================
# THICK FRAME FUNCTION
# =========================
frame_box() {
    local title="$1"
    local content="$2"
    local width=70  # fixed width for frames to avoid terminal tput issues

    # Top border
    echo -e "${B}‚ēĒ$(printf '‚ēź%.0s' $(seq 1 $width))‚ēó${W}"
    # Title
    printf "${B}‚ēĎ %-*s ‚ēĎ${W}\n" $width "‚Ėą‚Ėą‚Ėą‚Ėą $title ‚Ėą‚Ėą‚Ėą‚Ėą"
    # Separator
    echo -e "${B}‚ē†$(printf '‚ēź%.0s' $(seq 1 $width))‚ē£${W}"
    # Content lines
    while IFS= read -r line; do
        printf "${B}‚ēĎ %-*s ‚ēĎ${W}\n" $width "$line"
    done <<< "$content"
    # Bottom border
    echo -e "${B}‚ēö$(printf '‚ēź%.0s' $(seq 1 $width))‚ēĚ${W}"
}

# =========================
# HEADER
# =========================
clear
WIDTH=70
printf "%*s\n" $(((${WIDTH} + 60) / 2)) "‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó"
printf "%*s\n" $(((${WIDTH} + 60) / 2)) "‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ"
printf "%*s\n" $(((${WIDTH} + 60) / 2)) "‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēĎ   "
printf "%*s\n" $(((${WIDTH} + 60) / 2)) "‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   "
printf "%*s\n" $(((${WIDTH} + 60) / 2)) "‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   "
printf "%*s\n" $(((${WIDTH} + 25) / 2)) "GHOST TERMUX ASSISTANT"

# =========================
# SUPPORT PANEL
# =========================
frame_box "SUPPORT" "Heavy usage detected
Support server & AI:
Type 'd' or 'donate'
$SUPPORT_LINK"

# Open YouTube on start (optional)
if command -v termux-open-url &>/dev/null; then
    termux-open-url "https://www.youtube.com/@Mr_termux-r2l"
fi

# =========================
# INTERNET CHECK
# =========================
check_internet() {
    if ping -c 1 google.com &>/dev/null; then
        echo "[ ONLINE ]"
        return 0
    else
        echo "[ OFFLINE ]"
        return 1
    fi
}

frame_box "STATUS" "$(check_internet)"

touch "$MEMORY_FILE"

# =========================
# PROMPT
# =========================
prompt() {
    echo -en "${B}$DEVICE_NAME@ghost:~# ${W}"
}

# =========================
# OPEN DONATION
# =========================
open_donation() {
    if command -v termux-open-url &>/dev/null; then
        termux-open-url "$SUPPORT_LINK"
    else
        frame_box "SUPPORT" "$SUPPORT_LINK"
    fi
}

# =========================
# MAIN LOOP
# =========================
while true; do
    echo
    prompt
    read -r USER_INPUT

    # Donation shortcut
    if [[ "$USER_INPUT" == "d" || "$USER_INPUT" == "donate" ]]; then
        open_donation
        continue
    fi

    # Exit
    if [[ "$USER_INPUT" == "exit" ]]; then
        frame_box "SYSTEM" "SESSION TERMINATED"
        open_donation
        exit 0
    fi

    # Internet check
    if ! check_internet >/dev/null; then
        frame_box "ERROR" "NO INTERNET CONNECTION"
        continue
    fi

    echo "You: $USER_INPUT" >> "$MEMORY_FILE"

    frame_box "PROCESS" "SUMMONING GHOST AI..."

    # =========================
    # EXPLAIN MODE
    # =========================
    if [[ "$USER_INPUT" == explain* ]]; then
        QUERY="${USER_INPUT#explain }"
        RESPONSE=$(curl -sG "$AI_API" \
            --data-urlencode "text=Ghost, explain in detail Termux ethical hacking only: $QUERY" \
            | jq -r '.result.prompt')
        if [[ -z "$RESPONSE" || "$RESPONSE" == "null" ]]; then
            frame_box "ERROR" "EMPTY AI RESPONSE"
            continue
        fi
        frame_box "EXPLANATION" "$RESPONSE"
        echo "Ghost: $RESPONSE" >> "$MEMORY_FILE"
        continue
    fi

    # =========================
    # COMMAND MODE
    # =========================
    RAW_RESPONSE=$(curl -sG "$AI_API" \
        --data-urlencode "text=Ghost, ONLY reply with exact bash commands, no explanations, no comments, no quotes, no backticks, no markdown. Task: $USER_INPUT" \
        | jq -r '.result.prompt')

    RESPONSE=$(echo "$RAW_RESPONSE" | sed '/^\s*$/d' | sed 's/^[ \t]*//;s/[ \t]*$//')

    # Filter bad responses
    if echo "$RESPONSE" | grep -Ei 'please|remember|note|you can|Explanation|```|["'"'"'`‚Äú‚ÄĚ]'; then
        frame_box "ERROR" "INVALID AI RESPONSE"
        continue
    fi

    if [[ -z "$RESPONSE" || "$RESPONSE" == "null" ]]; then
        frame_box "ERROR" "EMPTY AI RESPONSE"
        continue
    fi

    frame_box "COMMAND" "$RESPONSE"
    echo "Ghost: $RESPONSE" >> "$MEMORY_FILE"

    # =========================
    # EXECUTION
    # =========================
    echo -en "${Y}EXECUTE? (y/n): ${W}"
    read -r CONFIRM

    if [[ "$CONFIRM" == "y" ]]; then
        echo "$RESPONSE" | while read -r line; do
            [[ -z "$line" ]] && continue
            eval "$line" || frame_box "ERROR" "FAILED: $line"
        done
    else
        frame_box "INFO" "EXECUTION SKIPPED"
    fi
done
