#!/data/data/com.termux/files/usr/bin/bash

# Ghost Termux Ethical Hacking Assistant - Animated Agent Mode
MEMORY_FILE="$HOME/.ghost_memory"
AI_API="https://api.giftedtech.co.ke/api/ai/gpt4o"
API_KEY="gifted"
DEVICE_NAME=$(uname -n)
SUPPORT_LINK="https://selar.com/showlove/alchemist"
YT_LINK="https://www.youtube.com/@Mr_termux-r2l"

# Colors
R="\033[1;31m" # Red
C="\033[1;36m" # Cyan
Y="\033[1;33m" # Yellow
G="\033[1;32m" # Green
W="\033[0m"    # Reset
BOLD="\033[1m"

# =========================
# ANIMATION FUNCTIONS
# =========================

type_effect() {
    local text="$1"
    local delay=${2:-0.02}
    for (( i=0; i<${#text}; i++ )); do
        echo -en "${text:$i:1}"
        sleep "$delay"
    done
    echo
}

loading_anim() {
    local pid=$!
    local delay=0.1
    local spinstr='|/-\'
    echo -en "${C}[#] GHOST IS ANALYZING "
    while [ -d /proc/$pid ]; do
        local temp=${spinstr#?}
        printf " [%c]  " "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b\b\b\b"
    done
    printf " [DONE]\n${W}"
}

# =========================
# SYSTEM UI FUNCTIONS
# =========================
frame_box() {
    local title="$1"
    local content="$2"
    local width=60
    echo -e "${C}‚ēĒ$(printf '‚ēź%.0s' $(seq 1 $width))‚ēó${W}"
    local title_str="[ $title ]"
    local t_pad=$(( (width - ${#title_str}) / 2 ))
    printf "${C}‚ēĎ%*s${R}${BOLD}%s${C}%*s‚ēĎ${W}\n" "$t_pad" "" "$title_str" "$((width - t_pad - ${#title_str}))" ""
    echo -e "${C}‚ē†$(printf '‚ēź%.0s' $(seq 1 $width))‚ē£${W}"
    while IFS= read -r line; do
        clean_line=$(echo -e "$line" | sed 's/\x1b\[[0-9;]*m//g')
        local c_pad=$(( (width - ${#clean_line}) / 2 ))
        printf "${C}‚ēĎ%*s${W}%s%*s${C}‚ēĎ${W}\n" "$c_pad" "" "$line" "$((width - c_pad - ${#clean_line}))" ""
    done <<< "$content"
    echo -e "${C}‚ēö$(printf '‚ēź%.0s' $(seq 1 $width))‚ēĚ${W}"
}

draw_header() {
    clear
    echo -e "${R}${BOLD}"
    header_text=$(cat << "EOF"
 ‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ
‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó    ‚Ėą‚Ėą‚ēĎ   
‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ   
‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ   
 ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ    ‚ēö‚ēź‚ēĚ   
EOF
)
    echo "$header_text"
    type_effect "            ${W}${BOLD}GHOST AGENT v3.0 - COMMAND PROTOCOL${W}" 0.01
    echo
}

# =========================
# STARTUP
# =========================
draw_header

# Open YouTube
if command -v termux-open-url &>/dev/null; then
    termux-open-url "$YT_LINK" &>/dev/null
fi

check_internet() {
    if ping -c 1 google.com &>/dev/null; then
        echo -e "${G}ONLINE - SYSTEM ENCRYPTED${W}"
    else
        echo -e "${R}OFFLINE - LIMITED PROTOCOLS${W}"
    fi
}

frame_box "STATUS" "$(check_internet)"
echo
frame_box "SUPPORT" "Heavy usage detected\nType 'd' or 'donate'\n$SUPPORT_LINK"
echo -e "\n${C}Ghost is listening...${W}"

# =========================
# MAIN AGENT LOOP
# =========================
while true; do
    echo -en "${R}${BOLD}‚ĒĆ‚ĒÄ‚ĒÄ(${C}${DEVICE_NAME}${R})‚ĒÄ[${Y}~${R}]\n‚ĒĒ‚ĒÄ${C}$ ${W}"
    read -r USER_INPUT

    [[ -z "$USER_INPUT" ]] && continue

    # Donation logic restored
    if [[ "$USER_INPUT" == "d" || "$USER_INPUT" == "donate" ]]; then
        type_effect "${R}[!] Opening Secure Support Link...${W}"
        termux-open-url "$SUPPORT_LINK" 2>/dev/null
        continue
    fi

    if [[ "$USER_INPUT" == "exit" ]]; then
        type_effect "${R}[!] DEACTIVATING GHOST AGENT... GOODBYE.${W}" 0.05
        exit 0
    fi

    if [[ "$USER_INPUT" == "clear" ]]; then
        draw_header
        continue
    fi

    # Silent System Prompt: Enforces Ghost persona and Termux-only commands
    SYSTEM_PROMPT="Your name is Ghost. You are a Termux Ethical Hacking Assistant. DO NOT mention ChatGPT or AI. Give ONLY the raw Termux/Bash command. No explanations. No stories. No conversational text."

    ( curl -sG "$AI_API" \
        --data-urlencode "apikey=$API_KEY" \
        --data-urlencode "q=$SYSTEM_PROMPT User: $USER_INPUT" > .tmp_resp ) &
    loading_anim
    
    # Cleaning the output to ensure it's a runnable command
    RESPONSE=$(jq -r '.result' .tmp_resp | sed 's/```bash//g; s/```//g; /^\s*$/d')
    rm .tmp_resp

    if [[ -z "$RESPONSE" || "$RESPONSE" == "null" ]]; then
        echo -e "${R}[!] CONNECTION TIMEOUT: AGENT DISCONNECTED${W}\n"
        continue
    fi

    echo -e "${R}${BOLD}Ghost Agent Response:${W}"
    
    # Command output
    type_effect "${G}${BOLD}  $RESPONSE${W}" 0.03
    echo
    echo -en "${Y}Execute? (y/n): ${W}"
    read -r CONFIRM
    if [[ "$CONFIRM" == "y" ]]; then
        echo -en "${C}[*] RUNNING PROTOCOLS... "
        eval "$RESPONSE"
        echo -e "${G}[DONE]${W}\n"
    else
        echo -e "${R}[-] VOIDED.${W}\n"
    fi
done
