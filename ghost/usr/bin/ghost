#!/data/data/com.termux/files/usr/bin/bash

# Ghost Termux Ethical Hacking Assistant - Agent Mode

MEMORY_FILE="$HOME/.ghost_memory"
AI_API="https://api.dreaded.site/api/chatgpt"
DEVICE_NAME=$(uname -n)
SUPPORT_LINK="https://selar.com/showlove/alchemist"

# Colors
R="\033[1;31m" # Red (Logo & Branding)
C="\033[1;36m" # Cyan (UI Elements)
Y="\033[1;33m" # Yellow (Prompts)
G="\033[1;32m" # Green (Success)
W="\033[0m"    # Reset
BOLD="\033[1m"

# =========================
# SYSTEM UI FUNCTIONS
# =========================
frame_box() {
    local title="$1"
    local content="$2"
    local width=60
    echo -e "${C}╔$(printf '═%.0s' $(seq 1 $width))╗${W}"
    local title_str="[ $title ]"
    local t_pad=$(( (width - ${#title_str}) / 2 ))
    printf "${C}║%*s${R}${BOLD}%s${C}%*s║${W}\n" "$t_pad" "" "$title_str" "$((width - t_pad - ${#title_str}))" ""
    echo -e "${C}╠$(printf '═%.0s' $(seq 1 $width))╣${W}"
    while IFS= read -r line; do
        clean_line=$(echo -e "$line" | sed 's/\x1b\[[0-9;]*m//g')
        local c_pad=$(( (width - ${#clean_line}) / 2 ))
        printf "${C}║%*s${W}%s%*s${C}║${W}\n" "$c_pad" "" "$line" "$((width - c_pad - ${#clean_line}))" ""
    done <<< "$content"
    echo -e "${C}╚$(printf '═%.0s' $(seq 1 $width))╝${W}"
}

draw_header() {
    clear
    echo -e "${R}${BOLD}"
    cat << "EOF"
  ░██████╗ ██╗  ██╗  ██████╗  ███████╗ ████████╗
 ██╔════╝ ██║  ██║ ██╔═══██╗ ██╔════╝ ╚══██╔══╝
 ██║  ███╗███████║ ██║   ██║ ███████╗    ██║   
 ██║   ██║██╔══██║ ██║   ██║ ╚════██║    ██║   
 ╚██████╔╝██║  ██║ ╚██████╔╝ ███████║    ██║   
  ╚═════╝ ╚═╝  ╚═╝  ╚═════╝  ╚══════╝    ╚═╝   
EOF
    echo -e "           ${W}${BOLD}GHOST AGENT v2.0${W}"
    echo
}

# =========================
# STARTUP
# =========================
draw_header
check_internet() {
    ping -c 1 google.com &>/dev/null && echo -e "${G}AGENT ONLINE${W}" || echo -e "${R}AGENT OFFLINE${W}"
}

frame_box "STATUS" "$(check_internet)"
echo -e "\n${C}Ghost is listening... type 'exit' to quit or 'clear' to reset.${W}\n"

# =========================
# AGENT MAIN LOOP
# =========================
while true; do
    echo -en "${R}${BOLD}┌──(${C}${DEVICE_NAME}${R})─[${Y}~${R}]\n└─${C}$ ${W}"
    read -r USER_INPUT

    [[ -z "$USER_INPUT" ]] && continue

    if [[ "$USER_INPUT" == "exit" ]]; then
        echo -e "\n${R}[!] Ghost is deactivating...${W}"
        exit 0
    fi

    if [[ "$USER_INPUT" == "clear" ]]; then
        draw_header
        continue
    fi

    echo -e "\n${C}[#] Ghost is thinking...${W}"
    echo "User: $USER_INPUT" >> "$MEMORY_FILE"

    # AI Request
    if [[ "$USER_INPUT" == explain* ]]; then
        QUERY="${USER_INPUT#explain }"
        RESPONSE=$(curl -sG "$AI_API" --data-urlencode "text=Ghost, explain: $QUERY" | jq -r '.result.prompt')
        
        echo -e "${R}${BOLD}Ghost Agent Response:${W}"
        echo -e "${W}$RESPONSE${W}\n"
    else
        RESPONSE=$(curl -sG "$AI_API" --data-urlencode "text=Ghost, ONLY bash command for: $USER_INPUT" | jq -r '.result.prompt' | sed '/^\s*$/d')

        if [[ -z "$RESPONSE" || "$RESPONSE" == "null" ]]; then
            echo -e "${R}[!] Error: Agent could not generate a command.${W}\n"
            continue
        fi

        echo -e "${R}${BOLD}Ghost Suggestion:${W}"
        echo -e "${G}${BOLD}  $RESPONSE${W}\n"
        
        echo -en "${Y}Execute this command? (y/n): ${W}"
        read -r CONFIRM
        if [[ "$CONFIRM" == "y" ]]; then
            echo -e "${C}[*] Executing...${W}"
            eval "$RESPONSE"
            echo -e "${G}[+] Task complete.${W}\n"
        else
            echo -e "${R}[-] Execution cancelled.${W}\n"
        fi
    fi
done
