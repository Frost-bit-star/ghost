#!/data/data/com.termux/files/usr/bin/bash

# Ghost Termux Ethical Hacking Assistant - Elite Red & Cyan UI

MEMORY_FILE="$HOME/.ghost_memory"
AI_API="https://api.dreaded.site/api/chatgpt"
DEVICE_NAME=$(uname -n)
SUPPORT_LINK="https://selar.com/showlove/alchemist"

# Colors
R="\033[1;31m" # Red (Logo & Errors)
C="\033[1;36m" # Cyan (Frame & UI)
Y="\033[1;33m" # Yellow (Prompts)
G="\033[1;32m" # Green (Success)
W="\033[0m"    # Reset
BOLD="\033[1m"

# =========================
# CENTERED THICK FRAME
# =========================
frame_box() {
    local title="$1"
    local content="$2"
    local width=64

    # Top border
    echo -e "${C}‚ēĒ$(printf '‚ēź%.0s' $(seq 1 $width))‚ēó${W}"
    
    # Centered Title logic
    local title_str="[ $title ]"
    local title_len=${#title_str}
    local t_pad=$(( (width - title_len) / 2 ))
    printf "${C}‚ēĎ%*s${R}${BOLD}%s${C}%*s‚ēĎ${W}\n" "$t_pad" "" "$title_str" "$((width - t_pad - title_len))" ""

    # Separator
    echo -e "${C}‚ē†$(printf '‚ēź%.0s' $(seq 1 $width))‚ē£${W}"

    # Centered Content lines
    while IFS= read -r line; do
        # Strip ANSI for length calc
        local clean_line=$(echo -e "$line" | sed 's/\x1b\[[0-9;]*m//g')
        local line_len=${#clean_line}
        
        if [ "$line_len" -ge "$width" ]; then
            printf "${C}‚ēĎ${W} %-$((width-2))s ${C}‚ēĎ${W}\n" "$line"
        else
            local c_pad=$(( (width - line_len) / 2 ))
            printf "${C}‚ēĎ%*s${W}%s%*s${C}‚ēĎ${W}\n" "$c_pad" "" "$line" "$((width - c_pad - line_len))" ""
        fi
    done <<< "$content"

    # Bottom border
    echo -e "${C}‚ēö$(printf '‚ēź%.0s' $(seq 1 $width))‚ēĚ${W}"
}

# =========================
# RED LOGO HEADER
# =========================
draw_header() {
    clear
    echo -e "${R}${BOLD}"
    cat << "EOF"
  ‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
 ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ
 ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó    ‚Ėą‚Ėą‚ēĎ   
 ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ   
 ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ   
  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ    ‚ēö‚ēź‚ēĚ   
EOF
    echo -e "           ${W}${BOLD}GHOST TERMUX ASSISTANT${W}"
    echo
}

draw_header

# =========================
# INITIAL CHECKS
# =========================
check_internet() {
    if ping -c 1 google.com &>/dev/null; then
        echo -e "${G}ONLINE SYSTEM READY${W}"
        return 0
    else
        echo -e "${R}OFFLINE - CHECK CONNECTION${W}"
        return 1
    fi
}

frame_box "SUPPORT" "Heavy usage detected\nType 'd' or 'donate' to support\n$SUPPORT_LINK"
frame_box "STATUS" "$(check_internet)"
touch "$MEMORY_FILE"

# =========================
# MAIN LOOP
# =========================
while true; do
    echo -en "${C}${DEVICE_NAME}${R}@${C}ghost${W}:${Y}~# ${W}"
    read -r USER_INPUT

    [[ -z "$USER_INPUT" ]] && continue

    # Navigation
    if [[ "$USER_INPUT" == "d" || "$USER_INPUT" == "donate" ]]; then
        termux-open-url "$SUPPORT_LINK" 2>/dev/null || frame_box "LINK" "$SUPPORT_LINK"
        continue
    fi

    if [[ "$USER_INPUT" == "exit" ]]; then
        frame_box "SYSTEM" "SESSION TERMINATED"
        exit 0
    fi

    if [[ "$USER_INPUT" == "clear" ]]; then
        draw_header
        continue
    fi

    echo "You: $USER_INPUT" >> "$MEMORY_FILE"
    frame_box "PROCESS" "CONSULTING GHOST AI..."

    # AI Interaction
    if [[ "$USER_INPUT" == explain* ]]; then
        QUERY="${USER_INPUT#explain }"
        RESPONSE=$(curl -sG "$AI_API" --data-urlencode "text=Ghost, explain: $QUERY" | jq -r '.result.prompt')
        frame_box "EXPLANATION" "$RESPONSE"
    else
        RESPONSE=$(curl -sG "$AI_API" --data-urlencode "text=Ghost, ONLY bash command for: $USER_INPUT" | jq -r '.result.prompt' | sed '/^\s*$/d')

        if [[ -z "$RESPONSE" || "$RESPONSE" == "null" ]]; then
            frame_box "ERROR" "AI FAILED TO GENERATE COMMAND"
            continue
        fi

        frame_box "COMMAND" "$RESPONSE"
        
        echo -en "${Y}EXECUTE? (y/n): ${W}"
        read -r CONFIRM
        if [[ "$CONFIRM" == "y" ]]; then
            eval "$RESPONSE"
        fi
    fi
done
